# Codex CLI credentials. The key is injected into each child process and never saved to SQLite.
CODEX_API_KEY=
# Legacy names remain supported for migration from the previous direct Chat Completions client.
MODEL_API_KEY=
DEEPSEEK_API_KEY=
# Codex uses an OpenAI-compatible Responses API endpoint and model identifier.
CODEX_BASE_URL=https://api.openai.com/v1
CODEX_MODEL=gpt-5.6
CODEX_COMMAND=codex
# Legacy endpoint/model names remain supported when CODEX_* values are blank.
DEEPSEEK_BASE_URL=
DEEPSEEK_MODEL=

# The QOJ site can be replaced at any time from the UI or this file.
QOJ_BASE_URL=http://124.221.91.212

# Docker executes generated C++ only with no network and resource limits.
REFERENCE_RUNNER_IMAGE=gcc:13
REFERENCE_RUNNER_TIMEOUT_SECONDS=5
REFERENCE_RUNNER_MEMORY_MB=512
