# Example only: replace with a tested version tag or, preferably, a registry digest.
CCPCOJ_IMAGE=csgrandeur/ccpcoj-judge:<tested-version-or-digest>
QOJ_BASE_URL=http://host.docker.internal:18080
CCPCOJ_JUDGE_USERNAME=judger
CCPCOJ_JUDGE_PASSWORD=replace-with-a-strong-password
CCPCOJ_PROCESS_NUM=1
CCPCOJ_CPUS=4
CCPCOJ_MEMORY=4g
CCPCOJ_SHM_SIZE=1g
CCPCOJ_SHM_RUN=0
CCPCOJ_OI_MODE=0
CCPCOJ_IGNORE_ESOL=1
CCPCOJ_TOP_DIFF_BYTES=2048
CCPCOJ_JAVA_TIME_BONUS=2
CCPCOJ_JAVA_MEMORY_BONUS=512
