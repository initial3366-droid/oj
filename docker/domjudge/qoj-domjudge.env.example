# QOJ 后端切换到 DOMjudge 判题时添加/修改这些环境变量
SPRING_PROFILES_ACTIVE=prod

QOJ_JUDGE_MODE=domjudge
ENABLE_UNSAFE_LOCAL_JUDGE=false
ENABLE_SANDBOX=false

# 如果 DOMjudge 和 QOJ 后端部署在同一台服务器，可用 127.0.0.1:8081。
# 如果不在同一台服务器，请改成 DOMjudge 服务器内网地址。
DOMJUDGE_BASE_URL=http://127.0.0.1:8081
DOMJUDGE_API_KEY=replace-with-domjudge-api-key
DOMJUDGE_DEFAULT_CONTEST_ID=replace-with-domjudge-contest-id
