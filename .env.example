# Backend dev port
SERVER_PORT=18080

# Vite API Proxy Target (开发环境)
VITE_API_PROXY_TARGET=http://127.0.0.1:18080

# WebSocket URL (开发环境自动使用代理，生产环境需配置)
VITE_WS_URL=/ws

# criyle/go-judge is bound to loopback and must use the same long random token
# as docker/go-judge/docker-compose.yml.
GO_JUDGE_BASE_URL=http://127.0.0.1:15050
GO_JUDGE_AUTH_TOKEN=<generate-with-openssl-rand-hex-32>
GO_JUDGE_CONNECT_TIMEOUT_MS=2000
GO_JUDGE_REQUEST_TIMEOUT_MS=200000
